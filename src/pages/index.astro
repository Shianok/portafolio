---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="NEODEV | Oscar Arce Ugalde" description="Portfolio de Oscar Arce Ugalde, Full Stack Developer.">
  <Navbar />
  <main>
    <Hero />
    
    <section id="projects" class="py-20 relative border-t border-white/5">
      <div class="absolute top-0 left-1/4 w-64 h-64 bg-neon-magenta/5 rounded-full blur-3xl z-[-1]"></div>
      
      <div class="mb-12">
        <span class="text-xs font-mono text-neon-magenta uppercase tracking-widest">// PORTFOLIO</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-2 mb-4">Featured <span class="text-neon-cyan">Projects</span></h2>
        <div class="w-20 h-1 bg-gradient-to-r from-neon-cyan to-neon-magenta"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  </main>
</Layout>
