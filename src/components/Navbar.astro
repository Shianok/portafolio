---
const base = import.meta.env.BASE_URL;

const links = [
  { name: 'home', num: '01', url: `${base}#home` },
  { name: 'expertise', num: '02', url: `${base}#expertise` },
  { name: 'projects', num: '03', url: `${base}#projects` },
];
---
<nav class="w-full py-8 flex items-center justify-between sticky top-0 bg-[#0b0d17]/80 backdrop-blur-md z-50 border-b border-white/5">
  <div class="flex items-center">
    <span class="text-xl font-bold font-display text-white tracking-wide">OscarArce.<span class="text-[#a855f7] animate-pulse">_</span></span>
  </div>
  
  <ul class="hidden md:flex items-center gap-10">
    {links.map(link => (
      <li>
        <a href={link.url} class="group flex items-center gap-2 text-sm font-sans text-gray-400 hover:text-white transition-colors duration-300">
          <span class="text-[#00f2ff] font-mono">{link.num}.</span>
          <span>// {link.name}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
